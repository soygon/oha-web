  <!-- Spaces -->
  <section id="spaces">
    <div class="container">
      <div class="spaces-header reveal">
        <div>
          <p class="section-label">Workspaces</p>
          <h2 class="section-title">Every kind of work,<br>perfectly equipped</h2>
        </div>
        <p class="spaces-intro">From deep solo focus to full team retreats — OHA has the space, technology and atmosphere for every professional need.</p>
      </div>
      <div class="spaces-grid">
        <div class="space-card reveal">
          <div class="space-icon">◈</div>
          <div class="space-name">Open coworking</div>
          <p class="space-desc">More than 40 ergonomic workstations with ocean views, high-speed fiber internet and a calm atmosphere designed for sustained concentration.</p>
        </div>
        <div class="space-card reveal">
          <div class="space-icon">◻</div>
          <div class="space-name">Private office</div>
          <p class="space-desc">Lockable private suites for individuals, small teams or executives who need absolute focus, privacy and a premium dedicated workspace.</p>
        </div>
        <div class="space-card reveal">
          <div class="space-icon">◎</div>
          <div class="space-name">Conference room</div>
          <p class="space-desc">A fully equipped conference hall and classroom for workshops, team retreats, presentations, training sessions and company offsites.</p>
        </div>
        <div class="space-card reveal">
          <div class="space-icon">▣</div>
          <div class="space-name">Call booths</div>
          <p class="space-desc">Soundproofed individual cabins for video calls, interviews, focused deep-work sessions and private conversations — always available.</p>
        </div>
        <div class="space-card reveal">
          <div class="space-icon">⊙</div>
          <div class="space-name">Recording studio</div>
          <p class="space-desc">Professional recording and podcast studio for content creators, educators, podcasters and remote teams producing high-quality media from Bali.</p>
        </div>
        <div class="space-card reveal">
          <div class="space-icon">◯</div>
          <div class="space-name">Ocean terrace</div>
          <p class="space-desc">Bamboo outdoor workspace and solarium terrace with unobstructed ocean and volcano views — the most inspiring backdrop for creative work in all of Bali.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why OHA -->
  <section id="advantage">
    <div class="container">
      <div class="reveal">
        <p class="section-label">Why OHA</p>
        <h2 class="section-title">Nothing else like it<br><em>in east Bali</em></h2>
      </div>
      <div class="advantage-grid">
        <div class="adv-item reveal">
          <div class="adv-title">Scale & completeness</div>
          <p class="adv-body">At over 1,400m², OHA is the largest and most complete professional hub in northeast Bali — with every facility under one roof and on one campus.</p>
        </div>
        <div class="adv-item reveal">
          <div class="adv-title">Proven track record</div>
          <p class="adv-body">Built by the team behind La Timba — Amed's original coworking, running for over 2 years. OHA is the next evolution, not just another promise.</p>
        </div>
        <div class="adv-item reveal">
          <div class="adv-title">Oceanfront location</div>
          <p class="adv-body">40 metres from Melasti Beach, Bali's finest coral reef area. Diving, paddle surf, kayaking and snorkelling all start directly at your doorstep.</p>
        </div>
        <div class="adv-item reveal">
          <div class="adv-title">Volcano sunsets</div>
          <p class="adv-body">Every evening the sun sets behind Mount Agung from our terrace. No other coworking in Bali can offer this view — or this energy.</p>
        </div>
      </div>
    </div>
  </section>

