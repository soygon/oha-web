---
// OHA Ocean Hub Amed — One-page landing v2
// oceanhubamed.com
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO Primary -->
  <title>OHA Ocean Hub Amed — Coworking & Coliving in Bali</title>
  <meta name="description" content="The most complete coworking and coliving space in Bali. Oceanfront in Amed — 1,400m² with private offices, recording studio, conference room, rooftop jacuzzi and direct views of Mount Agung. The must for digital nomads and remote teams in Bali." />
  <meta name="keywords" content="coworking Bali, coliving Bali, coworking Amed, best coworking Bali, digital nomad Bali, remote work Bali, coworking space Amed Bali, coliving Amed, recording studio Bali, private office Bali, east Bali coworking, podcast studio Bali, team retreat Bali, Ocean Hub Amed, OHA Bali, coworking northeast Bali" />
  <link rel="canonical" href="https://oceanhubamed.com/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://oceanhubamed.com/" />
  <meta property="og:title" content="OHA Ocean Hub Amed — Deep work by the ocean" />
  <meta property="og:description" content="Bali's most complete coworking & coliving. 1,400m² oceanfront in Amed — private offices, recording studio, volcano views, rooftop jacuzzi. Opening 2025." />
  <meta property="og:image" content="https://oceanhubamed.com/og-image.jpg" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Ocean Hub Amed" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="OHA Ocean Hub Amed — Deep work by the ocean" />
  <meta name="twitter:description" content="Bali's most complete coworking & coliving. 1,400m² oceanfront in Amed — private offices, recording studio, volcano views, rooftop jacuzzi." />
  <meta name="twitter:image" content="https://oceanhubamed.com/og-image.jpg" />

  <!-- Geo -->
  <meta name="geo.region" content="ID-BA" />
  <meta name="geo.placename" content="Amed, Bali, Indonesia" />
  <meta name="geo.position" content="-8.346;115.657" />
  <meta name="ICBM" content="-8.346, 115.657" />

  <!-- Schema.org -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["CoworkingSpace", "LodgingBusiness"],
    "name": "Ocean Hub Amed",
    "alternateName": "OHA",
    "description": "Bali's most complete premium coworking and coliving space. 1,400m² oceanfront in Amed, northeast Bali. Private offices, recording studio, conference room, call booths, rooftop jacuzzi, café and coliving with views of Mount Agung.",
    "url": "https://oceanhubamed.com",
    "logo": "https://oceanhubamed.com/logo/oha-v2.png",
    "image": "https://oceanhubamed.com/og-image.jpg",
    "email": "hello@oceanhubamed.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Melasti Beach, Amed",
      "addressLocality": "Amed",
      "addressRegion": "Bali",
      "addressCountry": "ID"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -8.346,
      "longitude": 115.657
    },
    "amenityFeature": [
      {"@type": "LocationFeatureSpecification", "name": "High-speed fiber internet", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Private offices", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Recording & podcast studio", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Conference room", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Soundproof call booths", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Rooftop jacuzzi", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Ocean view terrace", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Café and juice bar", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Coliving rooms", "value": true},
      {"@type": "LocationFeatureSpecification", "name": "Solarium terrace", "value": true}
    ],
    "priceRange": "$$-$$$",
    "currenciesAccepted": "USD, IDR",
    "openingHours": "Mo-Su 07:00-22:00"
  }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --navy:    #0F2A34;
      --teal:    #1E3F3A;
      --sand:    #D8CFC2;
      --cream:   #F2EFEA;
      --charcoal:#2B2E2F;
      --ocean:   #5BADA8;
      --sky:     #C4E4E2;
      --white:   #FFFFFF;

      /* Color del logo en el hero (fondo navy). Cámbialo en una línea si
         más adelante pones el logo sobre fondo claro: var(--navy). */
      --logo-color: var(--cream);
      --font-display: 'Cormorant Garamond', Georgia, serif;
      --font-body:    'Inter', system-ui, sans-serif;
      --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--cream);
      color: var(--navy);
      font-weight: 300;
      line-height: 1.75;
      overflow-x: hidden;
      font-size: 17px;
    }

    /* Nav */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.5rem 3.5rem;
      transition: background 0.4s var(--ease), backdrop-filter 0.4s;
    }
    nav.scrolled { background: rgba(15,42,52,0.94); backdrop-filter: blur(14px); }
    .nav-logo {
      font-family: var(--font-display); font-size: 1.15rem; font-weight: 400;
      color: var(--cream); letter-spacing: 0.18em; text-decoration: none; text-transform: uppercase;
    }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.78rem; font-weight: 400; letter-spacing: 0.14em;
      text-transform: uppercase; color: rgba(242,239,234,0.72); text-decoration: none; transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--sky); }

    /* Hero */
    #hero {
      position: relative; height: 100svh; min-height: 640px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        linear-gradient(180deg, rgba(15,42,52,0.60) 0%, rgba(30,63,58,0.45) 40%, rgba(91,173,168,0.20) 68%, rgba(15,42,52,0.75) 100%),
        linear-gradient(140deg, #0F2A34 0%, #1E3F3A 40%, #5BADA8 75%, #C4E4E2 100%);
    }
    .hero-horizon {
      position: absolute; top: 60%; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(196,228,226,0.35), transparent);
    }
    .hero-content { position: relative; z-index: 2; padding: 0 2rem; animation: fadeUp 1.2s var(--ease) both; }
    .hero-eyebrow {
      font-size: 0.78rem; font-weight: 400; letter-spacing: 0.28em;
      text-transform: uppercase; color: var(--sky); margin-bottom: 1.75rem;
    }
    .hero-logo {
      /* El PNG /logo/oha-v2.png es monocromo negro — lo usamos como mask
         para poder teñirlo con --logo-color desde CSS. */
      width: clamp(200px, 32vw, 360px);
      aspect-ratio: 767 / 354;
      margin: 0 auto 1.25rem;
      display: block;
      background-color: var(--logo-color);
      -webkit-mask: url('/logo/oha-v2.png') center / contain no-repeat;
              mask: url('/logo/oha-v2.png') center / contain no-repeat;
    }
    .hero-subtitle {
      font-size: 0.78rem; font-weight: 400; letter-spacing: 0.32em;
      text-transform: uppercase; color: rgba(196,228,226,0.75); margin-bottom: 1.75rem;
    }
    .hero-tagline {
      font-family: var(--font-display); font-style: italic;
      font-size: clamp(1.3rem, 2.8vw, 1.9rem); font-weight: 300;
      color: rgba(242,239,234,0.92); margin-bottom: 3rem;
    }
    .hero-cta {
      display: inline-block; padding: 1rem 3rem;
      border: 1px solid rgba(196,228,226,0.45); color: var(--sky);
      font-size: 0.75rem; font-weight: 400; letter-spacing: 0.22em;
      text-transform: uppercase; text-decoration: none; transition: all 0.3s var(--ease);
    }
    .hero-cta:hover { background: rgba(91,173,168,0.18); border-color: var(--sky); color: var(--white); }
    .hero-scroll {
      position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
      color: rgba(242,239,234,0.35); font-size: 0.62rem; letter-spacing: 0.22em;
      text-transform: uppercase; animation: pulse 2.5s ease-in-out infinite;
    }
    .scroll-line { width: 1px; height: 44px; background: linear-gradient(180deg, rgba(196,228,226,0.5), transparent); }
    .hero-wave { position: absolute; bottom: 0; left: 0; right: 0; }

    /* Sections */
    section { padding: 8rem 3.5rem; }
    .container { max-width: 1140px; margin: 0 auto; }
    .section-label {
      font-size: 0.72rem; font-weight: 400; letter-spacing: 0.26em;
      text-transform: uppercase; color: var(--ocean); margin-bottom: 1.25rem;
    }
    .section-title {
      font-family: var(--font-display); font-size: clamp(2.2rem, 4.5vw, 3.6rem);
      font-weight: 300; line-height: 1.12; color: var(--navy); margin-bottom: 1.75rem;
    }
    .section-body { font-size: 1.05rem; font-weight: 300; color: var(--charcoal); max-width: 620px; line-height: 1.9; }

    /* About */
    #about { background: var(--white); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5.5rem; align-items: center; }
    .about-visual {
      position: relative; height: 460px;
      background: linear-gradient(145deg, var(--navy) 0%, var(--teal) 55%, var(--ocean) 100%);
      border-radius: 2px; overflow: hidden; display: flex; align-items: center; justify-content: center;
    }
    .about-visual-oha {
      font-family: var(--font-display); font-size: 7rem; font-weight: 300;
      color: rgba(196,228,226,0.15); letter-spacing: -0.03em; user-select: none;
    }
    .about-visual-tag {
      position: absolute; bottom: 2rem; left: 2rem;
      font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--sky);
    }
    .about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.75rem; margin-top: 3rem; }
    .stat { border-top: 1px solid var(--sand); padding-top: 1.1rem; }
    .stat-number { font-family: var(--font-display); font-size: 2.5rem; font-weight: 300; color: var(--navy); line-height: 1; }
    .stat-label { font-size: 0.72rem; font-weight: 400; letter-spacing: 0.12em; color: var(--ocean); text-transform: uppercase; margin-top: 0.3rem; }

    /* Spaces */
    #spaces { background: var(--cream); }
    .spaces-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 4rem; gap: 2rem; }
    .spaces-intro { font-size: 1rem; color: var(--charcoal); max-width: 300px; font-weight: 300; line-height: 1.8; }
    .spaces-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: var(--sand); }
    .space-card { background: var(--white); padding: 2.75rem 2.25rem; transition: background 0.3s var(--ease); }
    .space-card:hover { background: var(--navy); }
    .space-card:hover .space-name, .space-card:hover .space-desc { color: var(--cream); }
    .space-card:hover .space-icon { color: var(--sky); }
    .space-icon { font-size: 1.4rem; margin-bottom: 1.5rem; color: var(--ocean); transition: color 0.3s; }
    .space-name { font-family: var(--font-display); font-size: 1.45rem; font-weight: 400; color: var(--navy); margin-bottom: 0.85rem; transition: color 0.3s; }
    .space-desc { font-size: 0.92rem; font-weight: 300; line-height: 1.8; color: var(--charcoal); transition: color 0.3s; }

    /* Advantage */
    #advantage { background: var(--cream); padding: 5rem 3.5rem; }
    .advantage-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; margin-top: 3.5rem; }
    .adv-item { border-top: 2px solid var(--ocean); padding-top: 1.5rem; }
    .adv-title { font-family: var(--font-display); font-size: 1.2rem; font-weight: 400; color: var(--navy); margin-bottom: 0.75rem; }
    .adv-body { font-size: 0.92rem; font-weight: 300; line-height: 1.8; color: var(--charcoal); }

    /* Location */
    #location { background: var(--navy); color: var(--cream); }
    #location .section-title { color: var(--cream); }
    #location .section-body { color: rgba(242,239,234,0.72); }
    .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5.5rem; align-items: center; }
    .location-features { margin-top: 3rem; display: flex; flex-direction: column; gap: 1.4rem; }
    .location-feature { display: flex; align-items: flex-start; gap: 1.1rem; padding-bottom: 1.4rem; border-bottom: 1px solid rgba(196,228,226,0.12); }
    .lf-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ocean); margin-top: 0.6rem; flex-shrink: 0; }
    .lf-text { font-size: 0.95rem; font-weight: 300; line-height: 1.7; color: rgba(242,239,234,0.72); }
    .lf-text strong { color: var(--sky); font-weight: 400; }
    .location-map {
      height: 440px; background: linear-gradient(145deg, var(--teal) 0%, #0d3240 100%);
      display: flex; align-items: center; justify-content: center; border: 1px solid rgba(196,228,226,0.08);
    }
    .map-coords { font-size: 0.68rem; letter-spacing: 0.22em; color: var(--ocean); text-transform: uppercase; margin-bottom: 1rem; text-align: center; }
    .map-name { font-family: var(--font-display); font-size: 2rem; font-weight: 300; color: var(--sky); text-align: center; }
    .map-sub { font-size: 0.75rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(196,228,226,0.4); margin-top: 0.5rem; text-align: center; }

    /* Coliving */
    #coliving { background: var(--white); }
    .coliving-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5.5rem; align-items: center; }
    .room-types { display: flex; flex-direction: column; margin-top: 2.25rem; }
    .room-type { display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 0; border-bottom: 1px solid var(--sand); }
    .room-type-name { font-family: var(--font-display); font-size: 1.2rem; font-weight: 400; color: var(--navy); }
    .room-type-detail { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ocean); }
    .coliving-visual {
      height: 500px; background: linear-gradient(185deg, var(--ocean) 0%, var(--teal) 55%, var(--navy) 100%);
      position: relative; display: flex; align-items: flex-end; padding: 2.5rem;
    }
    .coliving-visual-caption { font-family: var(--font-display); font-style: italic; font-size: 1.2rem; line-height: 1.6; color: rgba(242,239,234,0.55); }

    /* Waitlist */
    #notify { background: var(--navy); text-align: center; padding: 9rem 3.5rem; }
    #notify .section-label { color: var(--ocean); }
    #notify .section-title { color: var(--cream); font-size: clamp(2.2rem, 5vw, 4rem); margin: 0 auto 1.5rem; max-width: 700px; }
    #notify .section-body { color: rgba(242,239,234,0.65); margin: 0 auto; text-align: center; font-size: 1.05rem; }
    .notify-form { display: flex; max-width: 500px; margin: 3.5rem auto 0; }
    .notify-input {
      flex: 1; padding: 1.1rem 1.75rem;
      border: 1px solid rgba(196,228,226,0.2); border-right: none;
      background: rgba(255,255,255,0.05); font-family: var(--font-body); font-size: 0.95rem;
      color: var(--cream); outline: none; transition: border-color 0.2s;
    }
    .notify-input:focus { border-color: var(--ocean); }
    .notify-input::placeholder { color: rgba(242,239,234,0.3); }
    .notify-btn {
      padding: 1.1rem 2.25rem; background: var(--ocean); color: var(--navy);
      border: 1px solid var(--ocean); font-family: var(--font-body); font-size: 0.75rem;
      font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; cursor: pointer; transition: all 0.3s var(--ease);
    }
    .notify-btn:hover { background: var(--sky); border-color: var(--sky); }
    .notify-note { margin-top: 1.1rem; font-size: 0.75rem; color: rgba(196,228,226,0.35); letter-spacing: 0.05em; }

    /* Footer */
    footer { background: var(--charcoal); padding: 3rem 3.5rem; display: flex; justify-content: space-between; align-items: center; }
    .footer-brand { font-family: var(--font-display); font-size: 1rem; color: rgba(242,239,234,0.45); letter-spacing: 0.12em; }
    .footer-tagline { font-family: var(--font-display); font-style: italic; font-size: 0.95rem; color: rgba(196,228,226,0.35); }
    .footer-email { font-size: 0.78rem; letter-spacing: 0.1em; color: rgba(196,228,226,0.45); text-decoration: none; transition: color 0.2s; }
    .footer-email:hover { color: var(--sky); }

    /* Animations */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(32px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes pulse { 0%, 100% { opacity: 0.35; } 50% { opacity: 0.75; } }
    .reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.85s var(--ease), transform 0.85s var(--ease); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* Responsive */
    @media (max-width: 800px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      section { padding: 5rem 1.5rem; }
      #notify, #advantage { padding: 5rem 1.5rem; }
      .about-grid, .location-grid, .coliving-grid { grid-template-columns: 1fr; gap: 3rem; }
      .spaces-grid { grid-template-columns: 1fr; }
      .advantage-grid { grid-template-columns: 1fr 1fr; }
      .spaces-header { flex-direction: column; align-items: flex-start; }
      footer { flex-direction: column; gap: 1rem; text-align: center; }
      .notify-form { flex-direction: column; }
      .notify-input { border-right: 1px solid rgba(196,228,226,0.2); border-bottom: none; }
    }
    @media (max-width: 480px) { .advantage-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

  <nav id="navbar">
    <a href="#hero" class="nav-logo">Ocean Hub Amed</a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#spaces">Spaces</a></li>
      <li><a href="#location">Location</a></li>
      <li><a href="#coliving">Coliving</a></li>
      <li><a href="#notify">Get notified</a></li>
    </ul>
  </nav>

  <!-- Hero -->
  <section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-horizon"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Amed &nbsp;·&nbsp; Bali &nbsp;·&nbsp; Indonesia</p>

      <!-- OHA logo (oha-v2.png negro, teñido vía CSS mask a --logo-color) -->
      <div class="hero-logo" role="img" aria-label="OHA — Ocean Hub Amed"></div>

      <p class="hero-subtitle">Coliving &nbsp;&amp;&nbsp; Coworking</p>
      <p class="hero-tagline">Deep work by the ocean</p>
      <a href="#notify" class="hero-cta">Join the waitlist</a>
    </div>
    <div class="hero-scroll">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
    <svg class="hero-wave" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,20 1440,30 L1440,60 L0,60 Z" fill="#FFFFFF" opacity="0.06"/>
    </svg>
  </section>

  <!-- About -->
  <section id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-visual reveal">
          <span class="about-visual-oha">OHA</span>
          <span class="about-visual-tag">Melasti Beach &nbsp;·&nbsp; Amed &nbsp;·&nbsp; Bali</span>
        </div>
        <div class="reveal">
          <p class="section-label">About OHA</p>
          <h2 class="section-title">A technological oasis<br><em>on Bali's finest coast</em></h2>
          <p class="section-body">
            Ocean Hub Amed is not just a coworking space — it is a carefully designed environment where deep focus meets the raw beauty of the ocean. Set on Melasti Beach in Amed, northeast Bali, OHA spans more than 1,400 m² of premium workspace, coliving and lifestyle amenities, just 40 metres from the water's edge — with the sacred volcano Agung as a constant, dramatic backdrop.
          </p>
          <div class="about-stats">
            <div class="stat">
              <div class="stat-number">1,400<span style="font-size:1.3rem">m²</span></div>
              <div class="stat-label">Total campus</div>
            </div>
            <div class="stat">
              <div class="stat-number">40m</div>
              <div class="stat-label">From the ocean</div>
            </div>
            <div class="stat">
              <div class="stat-number">40+</div>
              <div class="stat-label">Work positions</div>
            </div>
            <div class="stat">
              <div class="stat-number">10+</div>
              <div class="stat-label">Coliving rooms</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spaces -->
  <section id="spaces">
    <div class="container">
      <div class="spaces-header reveal">
        <div>
          <p class="section-label">Workspaces</p>
          <h2 class="section-title">Every kind of work,<br>perfectly equipped</h2>
        </div>
        <p class="spaces-intro">From deep solo focus to full team retreats — OHA has the space, technology and atmosphere for every professional need.</p>
      </div>
      <div class="spaces-grid">
        <div class="space-card reveal">
          <div class="space-icon">◈</div>
          <div class="space-name">Open coworking</div>
          <p class="space-desc">More than 40 ergonomic workstations with ocean views, high-speed fiber internet and a calm atmosphere designed for sustained concentration.</p>
        </div>
        <div class="space-card reveal">
          <div class="space-icon">◻</div>
          <div class="space-name">Private office</div>
          <p class="space-desc">Lockable private suites for individuals, small teams or executives who need absolute focus, privacy and a premium dedicated workspace.</p>
        </div>
        <div class="space-card reveal">
          <div class="space-icon">◎</div>
          <div class="space-name">Conference room</div>
